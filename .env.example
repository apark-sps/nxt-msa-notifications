# Active Environment Profile (dev, qa, sbx)
APP_ENV=dev

# Server Configuration
SERVER_PORT=8085

# Kubernetes pod name — used as the RabbitMQ Stream consumer offset key.
# In local dev the hostname is used automatically; set this in K8s via fieldRef.
# POD_NAME=

# ─── Database Configuration ──────────────────────────────────────────────────
DB_HOST=localhost
DB_HOST_RO=localhost
DB_PORT=5432
DB_NAME=notifications
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_SSL_MODE=disable

# AWS Secrets Manager — overrides DB_* vars when set (production use)
# DB_SECRET_NAME=my-service/notifications/db-credentials

# ─── Broker Connectivity ─────────────────────────────────────────────────────
# AMQP (Quorum Queue — database persistence consumer)
AMQP_URI=amqp://guest:guest@localhost:5672/

# RabbitMQ Streams (fan-out broadcast consumer)
STREAM_URI=rabbitmq-stream://guest:guest@localhost:5552/

# Optional overrides — defaults are derived from APP_ENV (prefixed with 'sps-')
# AMQP_EXCHANGE=sps-dev-notifications-exchange-events
# AMQP_PERSIST_QUEUE=sps-dev-notifications-queue-persist
# AMQP_ROUTING_KEY=#
# STREAM_NAME=sps-dev-notifications-queue-broadcast
# STREAM_MAX_AGE_SECS=86400
